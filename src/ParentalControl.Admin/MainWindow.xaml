<Window x:Class="ParentalControl.Admin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ParentalControl.Admin.ViewModels"
        Title="Parental Control - Administration"
        Height="600" Width="1050"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <TabControl>
            <!-- Users Tab -->
            <TabItem Header="Users">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Refresh Users from System"
                                Command="{Binding LoadUsersCommand}"
                                Padding="15,5" />
                        <Button Content="Toggle Restricted"
                                Command="{Binding ToggleRestrictedCommand}"
                                Padding="15,5" Margin="10,0,0,0" />
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Users}"
                              SelectedItem="{Binding SelectedUser}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserAddRows="False">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                        <Setter Property="IsEnabled" Value="False" />
                                        <Setter Property="ToolTip" Value="You cannot place limits on Administrator Users. Change User Type to Standard User first" />
                                        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
                                        <Setter Property="Foreground" Value="Gray" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="130" />
                            <DataGridTextColumn Header="User Type" Binding="{Binding UserType}" Width="110" />
                            <DataGridTextColumn Header="SID" Binding="{Binding Sid}" Width="250" />
                            <DataGridCheckBoxColumn Header="Restricted" Binding="{Binding IsRestricted, Mode=OneWay}" Width="70" />
                            <DataGridTextColumn Header="Daily Limit" Binding="{Binding DailyMinutes, TargetNullValue='N/A'}" Width="80" />
                            <DataGridTextColumn Header="Schedule Start" Binding="{Binding ScheduleStart, TargetNullValue='N/A'}" Width="95" />
                            <DataGridTextColumn Header="Schedule End" Binding="{Binding ScheduleEnd, TargetNullValue='N/A'}" Width="90" />
                            <DataGridTextColumn Header="Today (min)" Binding="{Binding TodayMinutesUsed}" Width="85" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Limits Tab -->
            <TabItem Header="Limits">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="200" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                               Text="{Binding SelectedUser.Username, StringFormat='Configuration for: {0}', FallbackValue='Select a user from the Users tab'}"
                               FontSize="16" FontWeight="Bold" Margin="0,0,0,20" />

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="Daily Limit (minutes):"
                               VerticalAlignment="Center" Margin="0,5" />
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding DailyMinutes, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center" Margin="0,5" Padding="5,3" />

                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="Schedule Start:"
                               VerticalAlignment="Center" Margin="0,5" />
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Text="{Binding ScheduleStart, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center" Margin="0,5" Padding="5,3" />

                    <TextBlock Grid.Row="3" Grid.Column="0"
                               Text="Schedule End:"
                               VerticalAlignment="Center" Margin="0,5" />
                    <TextBox Grid.Row="3" Grid.Column="1"
                             Text="{Binding ScheduleEnd, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center" Margin="0,5" Padding="5,3" />

                    <Button Grid.Row="4" Grid.Column="1"
                            Content="Save Limits"
                            Command="{Binding SaveLimitsCommand}"
                            Padding="15,5" Margin="0,15,0,0"
                            HorizontalAlignment="Left" />
                </Grid>
            </TabItem>

            <!-- Usage Tab -->
            <TabItem Header="Usage">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Selected User: " VerticalAlignment="Center" />
                        <TextBlock Text="{Binding SelectedUser.Username, FallbackValue='None'}"
                                   VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,20,0" />
                        <Button Content="Refresh Usage"
                                Command="{Binding RefreshUsageCommand}"
                                Padding="15,5" />
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding UsageRecords}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="150" />
                            <DataGridTextColumn Header="Minutes Used" Binding="{Binding MinutesUsed}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Events Tab -->
            <TabItem Header="Events">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Button Content="Refresh Events"
                            Command="{Binding RefreshEventsCommand}"
                            Padding="15,5" Margin="0,0,0,10"
                            HorizontalAlignment="Left" />

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding EventRecords}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="170" />
                            <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="130" />
                            <DataGridTextColumn Header="User SID" Binding="{Binding UserSid}" Width="280" />
                            <DataGridTextColumn Header="Event Type" Binding="{Binding EventType}" Width="120" />
                            <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
