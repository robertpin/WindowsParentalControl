<UserControl x:Class="ParentalControl.Admin.Views.UserDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

    <DockPanel>
        <!-- Back button bar -->
        <Border DockPanel.Dock="Top" Padding="8,4">
            <Button Command="{Binding GoBackCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="ArrowLeft" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock Text="Back to Dashboard" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16,8,16,16">

                <!-- ═══ User Details ═══ -->
                <md:ColorZone Mode="PrimaryMid" Padding="8,6" CornerRadius="4" Margin="0,0,0,8">
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                Command="{Binding RefreshUserCommand}"
                                ToolTip="Refresh user details" Width="28" Height="28">
                            <md:PackIcon Kind="Refresh" Width="18" Height="18" />
                        </Button>
                        <TextBlock Text="User Details"
                                   FontSize="14" FontWeight="DemiBold"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </md:ColorZone>

                <md:Card Padding="20" Margin="0,0,0,24" md:ElevationAssist.Elevation="Dp2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Username -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="USERNAME" FontSize="10" Opacity="0.5"
                                   FontWeight="SemiBold" />
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="{Binding User.Username}"
                                   FontSize="18" FontWeight="Bold" Margin="0,2,0,0" />

                        <!-- SID -->
                        <TextBlock Grid.Row="0" Grid.Column="2"
                                   Text="SID" FontSize="10" Opacity="0.5"
                                   FontWeight="SemiBold" />
                        <TextBlock Grid.Row="1" Grid.Column="2"
                                   Text="{Binding User.Sid}"
                                   FontSize="14" Margin="0,2,0,0" />

                        <!-- Account Type -->
                        <TextBlock Grid.Row="0" Grid.Column="4"
                                   Text="ACCOUNT TYPE" FontSize="10" Opacity="0.5"
                                   FontWeight="SemiBold" />
                        <TextBlock Grid.Row="1" Grid.Column="4"
                                   Text="{Binding User.UserType}"
                                   FontSize="14" Margin="0,2,0,0" />

                        <!-- Restricted -->
                        <TextBlock Grid.Row="0" Grid.Column="6"
                                   Text="RESTRICTED" FontSize="10" Opacity="0.5"
                                   FontWeight="SemiBold" />
                        <TextBlock Grid.Row="1" Grid.Column="6"
                                   Text="{Binding User.IsRestricted}"
                                   FontSize="14" Margin="0,2,0,0" />

                        <!-- Today's Usage -->
                        <TextBlock Grid.Row="0" Grid.Column="8"
                                   Text="TODAY'S USAGE" FontSize="10" Opacity="0.5"
                                   FontWeight="SemiBold" />
                        <TextBlock Grid.Row="1" Grid.Column="8"
                                   Text="{Binding User.TodayMinutesUsed, StringFormat='{}{0} min'}"
                                   FontSize="14" Margin="0,2,0,0" />
                    </Grid>
                </md:Card>

                <!-- ═══ User Limits ═══ -->
                <md:ColorZone Mode="PrimaryMid" Padding="8,6" CornerRadius="4" Margin="0,0,0,8">
                    <TextBlock Text="User Limits"
                               FontSize="14" FontWeight="DemiBold"
                               Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                               VerticalAlignment="Center" />
                </md:ColorZone>

                <md:Card Padding="20" Margin="0,0,0,24" md:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     md:HintAssist.Hint="Daily Usage (minutes)"
                                     md:HintAssist.IsFloating="True"
                                     Text="{Binding DailyMinutes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                            <TextBox Grid.Column="2"
                                     md:HintAssist.Hint="Schedule Start (HH:mm)"
                                     md:HintAssist.IsFloating="True"
                                     Text="{Binding ScheduleStart, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                            <TextBox Grid.Column="4"
                                     md:HintAssist.Hint="Schedule End (HH:mm)"
                                     md:HintAssist.IsFloating="True"
                                     Text="{Binding ScheduleEnd, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <Button Content="Set Limits"
                                    Command="{Binding SetLimitsCommand}"
                                    Style="{StaticResource MaterialDesignPaperButton}"
                                    Padding="24,8" Margin="0,0,12,0" />
                            <Button Content="Remove Limits"
                                    Command="{Binding RemoveLimitsCommand}"
                                    Background="#D32F2F" Foreground="White"
                                    BorderBrush="#D32F2F"
                                    Style="{StaticResource MaterialDesignPaperButton}"
                                    Padding="24,8" />
                        </StackPanel>
                    </StackPanel>
                </md:Card>

                <!-- ═══ Events ═══ -->
                <md:ColorZone Mode="PrimaryMid" Padding="8,6" CornerRadius="4" Margin="0,0,0,8">
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                Command="{Binding RefreshEventsCommand}"
                                ToolTip="Refresh events" Width="28" Height="28">
                            <md:PackIcon Kind="Refresh" Width="18" Height="18" />
                        </Button>
                        <TextBlock Text="Events"
                                   FontSize="14" FontWeight="DemiBold"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </md:ColorZone>

                <DataGrid ItemsSource="{Binding EventRecords}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          MaxHeight="400"
                          Margin="0,0,0,16"
                          PreviewMouseWheel="DataGrid_PreviewMouseWheel">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="170" />
                        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="130" />
                        <DataGridTextColumn Header="User SID" Binding="{Binding UserSid}" Width="280" />
                        <DataGridTextColumn Header="Event Type" Binding="{Binding EventType}" Width="120" />
                        <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
